server {
    listen       80;
    server_name  localhost;

    # For Docker only to resolve sibling containers
    resolver 127.0.0.11;

    #access_log  /var/log/nginx/host.access.log  main;

    location / {
        root /var/www/public;
        try_files $uri $uri/ @app;
        gzip_static on;
    }

    location = / {
        proxy_pass http://${APP_HOST}:${APP_PORT}$uri?$query_string;
    }

    location @app {
        proxy_pass http://${APP_HOST}:${APP_PORT}$uri?$query_string;
    }
}
